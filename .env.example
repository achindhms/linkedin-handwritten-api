# Copy this to .env and fill in your own values.

# Port the server listens on. Render sets this automatically — you don't need
# to set it yourself when deploying there.
PORT=3000

# One or more API keys, comma-separated, required as the x-api-key header on
# /generate, /generate/bulk, and /stats. Leave blank while testing locally;
# set at least one real value before exposing this publicly.
# Example with two keys (e.g. one for you, one for a teammate/n8n instance):
#   API_KEYS=n8n-prod-8f3a1c2e9b7d4f60,personal-testing-key
API_KEYS=change-me-to-a-long-random-string

# Restrict which browser origins can call this via CORS (comma-separated).
# Leave blank to allow all origins — fine for a server-to-server tool like n8n,
# since n8n's HTTP Request node isn't subject to CORS anyway. Only matters if
# you're calling this directly from a website's JavaScript.
ALLOWED_ORIGINS=

# How many requests per minute, per IP, /generate will accept before responding
# 429. Raise this if a legitimate bulk workflow is tripping it.
RATE_LIMIT_PER_MINUTE=60

NODE_ENV=production
